{
	"name": "n8n-nodes-lfrank-meta-publisher",
	"version": "0.15.1",
	"description": "Fork by Ludovic Frank — publish to Instagram, Facebook Pages, and Threads (images, videos, reels, stories, carousels) via Meta Graph APIs.",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"workflow",
		"instagram",
		"facebook",
		"threads",
		"meta",
		"publisher",
		"post",
		"social media"
	],
	"license": "MIT",
	"homepage": "https://github.com/ralphcrisostomo/n8n-nodes-meta-publisher",
	"author": {
		"name": "Ludovic Frank",
		"email": "ludo@hey.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ralphcrisostomo/n8n-nodes-meta-publisher.git"
	},
	"engines": {
		"node": ">=20.15"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "n8n-node build && node --test \"test/**/*.test.js\"",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/MetaGraphApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MetaPublisher/MetaPublisher.node.js",
			"dist/nodes/MetaPublisherUtils/MetaPublisherUtils.node.js",
			"dist/nodes/MetaPublisherJsonGenerator/MetaPublisherJsonGenerator.node.js",
			"dist/nodes/MetaPublisherBinaryUpload/MetaPublisherBinaryUpload.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	}
}
